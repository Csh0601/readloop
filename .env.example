# Claude-compatible endpoint (optional fallback)
CLAUDE_API_KEY=your_claude_api_key_here
CLAUDE_BASE_URL=https://api.example.com/v1
CLAUDE_MODEL=claude-sonnet-4-6-n

# DeepSeek-compatible endpoint (primary by default)
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# Local data paths
REFERENCE_DIR_1=D:/wu/reference paper
REFERENCE_DIR_2=D:/agentmemory/papers
OUTPUT_DIR=D:/wu/output

# LLM calls direct-connect by default; set to 1 only if your API must use a proxy.
READLOOP_LLM_TRUST_ENV=0

# Optional proxy for sentence-transformers / Hugging Face downloads.
EMBEDDING_HTTP_PROXY=
EMBEDDING_HTTPS_PROXY=
EMBEDDING_ALL_PROXY=
